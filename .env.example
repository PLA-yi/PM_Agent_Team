# ==== LLM ====
# OpenRouter (https://openrouter.ai/keys) — 留空则进入 mock 模式（返回固定 fixture）
OPENROUTER_API_KEY=
# 默认模型；mock 模式下忽略
LLM_MODEL=anthropic/claude-sonnet-4.6

# ==== Search & Scrape ====
# Tavily (https://tavily.com) — 留空进入 mock
TAVILY_API_KEY=
# Jina Reader 不需要 key，免费走 r.jina.ai

# ==== Database ====
DATABASE_URL=postgres://pmhive:pmhive@localhost:5432/pmhive?sslmode=disable

# ==== Server ====
HTTP_ADDR=:8080
# 允许跨域来源（开发环境前端 vite）
CORS_ORIGINS=http://localhost:5173

# ==== Mock Mode ====
# 强制走 mock（即使有 key），用于 demo 和测试
MOCK_MODE=auto   # auto | always | never
